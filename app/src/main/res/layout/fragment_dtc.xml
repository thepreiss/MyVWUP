<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <View
        android:id="@+id/dtc_header_bg"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#1A1A1A"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/dtc_header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DIAGNÓSTICO DE ERROS"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/dtc_header_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/dtc_header_bg" />

    <LinearLayout
        android:id="@+id/dtc_actions_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/dtc_header_bg">

        <Button
            android:id="@+id/action_scan_dtc"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:backgroundTint="#01804F"
            android:text="@string/dtc_action_scan"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <Button
            android:id="@+id/action_clear_dtc"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:backgroundTint="#C41E3A"
            android:text="@string/dtc_action_clear"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dtc_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dtc_actions_panel"
        tools:listitem="@layout/item_dtc" />

    <TextView
        android:id="@+id/dtc_empty_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dtc_no_errors"
        android:textColor="#80FFFFFF"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dtc_actions_panel" />

</androidx.constraintlayout.widget.ConstraintLayout>
